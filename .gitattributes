# Exclude dev/build files from Packagist distribution
ecs.php              export-ignore
phpstan.neon         export-ignore
scripts/             export-ignore

# Field and frontend assets: only dist/ and Prism vendor files are needed
src/web/assets/field/src/          export-ignore
src/web/assets/frontend/src/       export-ignore
src/web/assets/node_modules/       export-ignore
src/web/assets/package.json        export-ignore
src/web/assets/package-lock.json   export-ignore

# Docs are available on the website
docs/                export-ignore
